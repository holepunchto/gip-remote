{
  "name": "gip-remote",
  "version": "1.0.1",
  "description": "Git+Pear remote DB for handling git data",
  "main": "index.js",
  "scripts": {
    "format": "prettier . --write",
    "test": "brittle-bare test/all.js",
    "lint": "prettier . --check && lunte"
  },
  "type": "commonjs",
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "child_process": {
      "bare": "bare-subprocess",
      "default": "child_process"
    }
  },
  "exports": {
    "./package": "./package.json",
    ".": {
      "default": "./index.js"
    },
    "./git": {
      "default": "./lib/git.js"
    },
    "./schema/hyperdb": {
      "default": "./schema/hyperdb/index.js"
    },
    "./schema/hyperschema": {
      "default": "./schema/hyperschema/index.js"
    }
  },
  "files": [
    "package.json",
    "index.js",
    "index.d.ts",
    "lib",
    "schema"
  ],
  "keywords": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/gip-remote.git"
  },
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/gip-remote/issues"
  },
  "homepage": "https://github.com/holepunchto/gip-remote",
  "devDependencies": {
    "b4a": "^1.8.0",
    "bare-subprocess": "^5.2.3",
    "brittle": "^3.19.1",
    "corestore": "^7.9.2",
    "hyperdht": "^6.29.6",
    "hyperswarm": "^4.17.0",
    "prettier": "^3.8.1",
    "prettier-config-holepunch": "^2.0.0",
    "test-tmp": "^1.4.0",
    "z32": "^1.1.0"
  },
  "dependencies": {
    "bare-fs": "^4.5.6",
    "bare-path": "^3.0.0",
    "hyperbee2": "^2.8.0",
    "hyperdb": "^6.3.0",
    "mirror-drive": "^1.13.0",
    "pear-link": "^4.2.1",
    "ready-resource": "^1.2.0",
    "rebuild-git": "^1.1.1",
    "streamx": "^2.25.0"
  }
}
